import json
from pydantic import BaseModel, Field

from agent1_extractor import ExtractedCase, run_extractor
from agent2_icd_coder import ICDResult, run_icd_coder, check_confidence_gate
from agent3_policy_rag import PolicyCheckResult, run_policy_rag


class PriorAuthForm(BaseModel):
    patient_age: int
    patient_sex: str
    diagnosis: str
    icd10_code: str
    icd10_description: str
    requested_procedure: str
    failed_treatments_summary: str
    policy_match: bool
    supporting_criteria: list[str]
    missing_criteria: list[str]
    recommendation: str = Field(description="APPROVE, DENY, or REVIEW")


def run_form_filler(case: ExtractedCase, icd_result: ICDResult, policy_result: PolicyCheckResult) -> PriorAuthForm:
    if policy_result.policy_match and policy_result.confidence >= 0.85:
        recommendation = "APPROVE"
    elif policy_result.missing_items:
        recommendation = "DENY"
    else:
        recommendation = "REVIEW"

    form = PriorAuthForm(
        patient_age=case.age,
        patient_sex=case.sex,
        diagnosis=case.diagnosis,
        icd10_code=icd_result.icd10_code,
        icd10_description=icd_result.icd10_description,
        requested_procedure=case.requested_procedure,
        failed_treatments_summary=", ".join(case.failed_treatments),
        policy_match=policy_result.policy_match,
        supporting_criteria=policy_result.matched_criteria,
        missing_criteria=policy_result.missing_items,
        recommendation=recommendation,
    )
    return form


if __name__ == "__main__":
    doctor_note = """
    Patient: 64F with severe right knee pain for 18 months.
    X-ray shows advanced osteoarthritis. Failed NSAIDs, physiotherapy, and intra-articular steroid injection.
    Orthopedic surgeon recommends total knee replacement.
    """

    case = run_extractor(doctor_note)
    icd_result = run_icd_coder(case)
    gate_status = check_confidence_gate(icd_result)

    if gate_status == "SUSPENDED_FOR_HUMAN_REVIEW":
        print("Workflow suspended — case sent to human reviewer. Stopping here.")
    else:
        policy_result = run_policy_rag(case, icd_result)
        final_form = run_form_filler(case, icd_result, policy_result)

        print("FINAL PRIOR-AUTH FORM:")
        print(final_form.model_dump_json(indent=2))
