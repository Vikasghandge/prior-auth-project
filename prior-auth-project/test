import os
import json
from dotenv import load_dotenv
from openai import AzureOpenAI
from pydantic import BaseModel, Field
from typing import List

load_dotenv()

client = AzureOpenAI(
    azure_endpoint=os.getenv("AZURE_OPENAI_ENDPOINT"),
    api_key=os.getenv("AZURE_OPENAI_API_KEY"),
    api_version=os.getenv("AZURE_OPENAI_API_VERSION"),
)
deployment = os.getenv("AZURE_OPENAI_DEPLOYMENT")


class ExtractedCase(BaseModel):
    age: int = Field(description="Patient age in years")
    sex: str = Field(description="Patient sex, e.g. 'M' or 'F'")
    diagnosis: str = Field(description="Primary diagnosis described in the note")
    failed_treatments: List[str] = Field(description="List of treatments already tried and failed")
    imaging_evidence: str = Field(description="What imaging (X-ray, MRI etc.) showed")
    requested_procedure: str = Field(description="The procedure the doctor is requesting authorization for")


def run_extractor(doctor_note: str) -> ExtractedCase:
    prompt = f"""
Extract structured information from this doctor's note.

DOCTOR NOTE:
{doctor_note}

Respond ONLY with valid JSON matching exactly this structure, no extra text, no markdown:
{{
  "age": <number>,
  "sex": "<M or F>",
  "diagnosis": "<text>",
  "failed_treatments": ["<text>", "<text>"],
  "imaging_evidence": "<text>",
  "requested_procedure": "<text>"
}}
"""

    response = client.chat.completions.create(
        model=deployment,
        messages=[{"role": "user", "content": prompt}],
        temperature=0,
    )

    raw_text = response.choices[0].message.content.strip()

    # Remove markdown fences if the model added them anyway
    if raw_text.startswith("```"):
        raw_text = raw_text.strip("`")
        raw_text = raw_text.replace("json", "", 1).strip()

    data = json.loads(raw_text)          # turn AI's text into a Python dict
    validated = ExtractedCase(**data)    # Pydantic checks it matches our schema
    return validated


if __name__ == "__main__":
    doctor_note = """
    Patient: 64F with severe right knee pain for 18 months.
    X-ray shows advanced osteoarthritis. Failed NSAIDs, physiotherapy, and intra-articular steroid injection.
    Orthopedic surgeon recommends total knee replacement.
    """

    result = run_extractor(doctor_note)
    print("AGENT 1 OUTPUT (validated by Pydantic):")
    print(result.model_dump_json(indent=2))
